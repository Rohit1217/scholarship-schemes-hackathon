# Copy to .env for local dev only — never commit .env
# Prefer Databricks secret scope `scholarship` in the workspace.

DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=<your-pat>
SARVAM_API_KEY=<your-sarvam-key>

# LLM endpoint (AI Gateway — copy from Playground "Get code")
LLM_OPENAI_BASE_URL=https://<workspace-id>.ai-gateway.cloud.databricks.com/mlflow/v1
LLM_MODEL=databricks-meta-llama-3-1-70b-instruct

# FAISS index paths (UC Volume paths when running on Databricks, local paths for local dev)
FAISS_INDEX_PATH=/Volumes/main/scholarships/rag/faiss.index
FAISS_META_PATH=/Volumes/main/scholarships/rag/metadata.parquet

LOG_LEVEL=INFO
